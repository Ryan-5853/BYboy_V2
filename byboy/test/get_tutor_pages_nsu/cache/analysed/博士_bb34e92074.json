    "research_directions": [
      {
        "title": "微波设计智能体",
        "description": "通过融合多模态感知、跨尺度协同优化、强化学习及生成式大模型等前沿技术，构建具备自主认知与决策能力的微波设计智能体（Agent）。打造从“需求定义”到“成品生成”的自动化闭环新范式，提升设计效率与创新维度。"
      },
      {
        "title": "电磁对抗仿真软件",
        "description": "自研电磁/半导体/环境全链条软件工具，融合AI智能决策算法攻克智能博弈决策算法，打造复杂电磁环境下系统设计与评估的自主可控一体化方案。"
      },
      {
        "title": "云边协同计算",
        "description": "构建高效能端侧AI架构与云边混合计算体系，突破边缘侧算力与存储的资源瓶颈；建立“云侧大模型推理 + 端侧小模型执行”的协同机制，实现分布式智能诊断与敏捷部署，赋能垂直领域的云边联动物联网应用。"
      }
    ],
