# 应用启动时会自动加载本文件（python-dotenv）
# 建议：只保留“当前生效”配置，其他方案放到“自定义链路扩展区”注释保存。

# ============================================================================
# 1) Packy 网关（全部调用链路都走 packyapi）
# ============================================================================
PACKY_API_KEY=
PACKY_BASE_URL=https://www.packyapi.com
PACKY_ANTHROPIC_BASE_URL=https://www.packyapi.com

# 视觉链路可独立 key / base，不填则回退到上面的 PACKY_*。
# PACKY_VISION_API_KEY=
# PACKY_VISION_BASE_URL=https://www.packyapi.com
# PACKY_VISION_OPENAI_BASE_URL=https://www.packyapi.com
# PACKY_VISION_ANTHROPIC_BASE_URL=https://www.packyapi.com

# ============================================================================
# 2) 通道级默认模型（槽位未显式指定时的兜底）
# ============================================================================
BYBOY_OPENAI_MODEL=gpt-4o-mini
BYBOY_CLAUDE_MODEL=claude-3-5-haiku-20241022
BYBOY_LLM_DEFAULT_ROUTE=claude

# 视觉通道默认模型（供 BYBOY_SLOT_VISION 或 vision 兜底）
BYBOY_VISION_MODEL=gemini-2.5-flash-image
BYBOY_VISION_BACKEND=openai

# 可选：通道级温度 / token 默认值（对应 RouteSpec）
# BYBOY_OPENAI_TEMPERATURE=0
# BYBOY_OPENAI_MAX_TOKENS=
# BYBOY_CLAUDE_TEMPERATURE=0
# BYBOY_CLAUDE_MAX_TOKENS=
# BYBOY_VISION_TEMPERATURE=0
# BYBOY_VISION_MAX_TOKENS=

# ============================================================================
# 3) 槽位代号（推荐 agent / CLI 直接传 BYBOY_SLOT_*）
# ============================================================================
# 说明：
# - 每个代号只配两个变量：BYBOY_SLOT_<NAME>_MODEL + BYBOY_SLOT_<NAME>_API_KEY
# - MODEL 支持 backend:model 或裸模型id（裸模型按前缀推断 backend）
# - 支持 backend：openai / claude / openai_vision / claude_vision
# - CLI 示例：--route BYBOY_SLOT_DEFAULT / --route BYBOY_SLOT_VISION

# 标准槽位（建议保留）
# BYBOY_SLOT_DEFAULT_MODEL=claude:claude-3-5-haiku-20241022
# BYBOY_SLOT_DEFAULT_API_KEY=
# BYBOY_SLOT_REASONING_MODEL=claude:claude-3-5-haiku-20241022
# BYBOY_SLOT_REASONING_API_KEY=
# BYBOY_SLOT_CODE_MODEL=openai:gpt-4o-mini
# BYBOY_SLOT_CODE_API_KEY=
# BYBOY_SLOT_FAST_MODEL=openai:gpt-4o-mini
# BYBOY_SLOT_FAST_API_KEY=
# BYBOY_SLOT_VISION_MODEL=openai_vision:gemini-2.5-flash-image
# BYBOY_SLOT_VISION_API_KEY=

# 自定义链路扩展区（按业务继续添加）
# BYBOY_SLOT_TOOLCALL_MODEL=openai:gpt-4.1
# BYBOY_SLOT_TOOLCALL_API_KEY=
# BYBOY_SLOT_BATCH_MODEL=claude:claude-3-5-haiku-20241022
# BYBOY_SLOT_BATCH_API_KEY=
# BYBOY_SLOT_LONGCTX_MODEL=openai:gpt-4.1-mini
# BYBOY_SLOT_LONGCTX_API_KEY=
# BYBOY_SLOT_EXPERIMENT_A_MODEL=openai:gpt-4o-mini
# BYBOY_SLOT_EXPERIMENT_A_API_KEY=
# BYBOY_SLOT_EXPERIMENT_B_MODEL=claude:claude-sonnet-4-5-20250929
# BYBOY_SLOT_EXPERIMENT_B_API_KEY=

# ============================================================================
# 4) 兼容旧变量（可不填）
# ============================================================================
# PACKYAPI_API_KEY=
# PACKYAPI_BASE_URL=https://www.packyapi.com
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# MODEL_ANALYST=claude-opus-4-6
# MODEL_OPERATOR=claude-opus-4-6
# MODEL=claude-opus-4-6
# BYBOY_TEST_OPENAI_MODEL=
# BYBOY_TEST_CLAUDE_MODEL=

# ============================================================================
# 5) Firecrawl
# ============================================================================
# FIRECRAWL_API_KEY=
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev
# FIRECRAWL_API_VERSION=v2
