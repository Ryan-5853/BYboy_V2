# 复制为 .env 后填写。应用启动时会通过 python-dotenv 自动加载（见 byboy.env_loader）。

# ---------- Packy / 网关 API ----------
# 任选其一：BYboy 与旧仓库 tests/web_clean、tests/link_choose 的变量名均支持
PACKY_API_KEY=
# PACKYAPI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=

# OpenAI 兼容 Chat Completions 根（可写域名，会自动补 /v1）；可与旧项目 PACKYAPI_BASE_URL 二选一
PACKY_BASE_URL=https://www.packyapi.com
# PACKYAPI_BASE_URL=https://www.packyapi.com

# Anthropic Messages 根路径（不要带 /v1）。不填时默认与 PACKY_BASE_URL / PACKYAPI_BASE_URL 同源（并剥 /v1）
PACKY_ANTHROPIC_BASE_URL=https://www.packyapi.com

# ---------- 模型与路由（BYboy）----------
BYBOY_OPENAI_MODEL=gpt-4o-mini
BYBOY_CLAUDE_MODEL=claude-3-5-haiku-20241022
# 未设 BYBOY_CLAUDE_MODEL 时，可沿用旧项目 MODEL_ANALYST → MODEL_OPERATOR → MODEL（支持 anthropic/ 前缀）
# MODEL_ANALYST=claude-opus-4-6
# MODEL=claude-opus-4-6

# 未配置 BYBOY_SLOT_DEFAULT 时，default 槽位沿用哪条底层通道：claude 或 openai
BYBOY_LLM_DEFAULT_ROUTE=claude

# 语义槽位（推理 / 代码 / 快反等），值为 openai:模型id 或 claude:模型id
# BYBOY_SLOT_DEFAULT=claude:claude-3-5-haiku-20241022
# BYBOY_SLOT_REASONING=claude:claude-3-5-haiku-20241022
# BYBOY_SLOT_CODE=openai:gpt-4o-mini
# BYBOY_SLOT_FAST=openai:gpt-4o-mini

# 可选：写入 RouteSpec，未设置则不在调用时注入
# BYBOY_OPENAI_TEMPERATURE=0
# BYBOY_OPENAI_MAX_TOKENS=
# BYBOY_CLAUDE_TEMPERATURE=0
# BYBOY_CLAUDE_MAX_TOKENS=

# 兼容旧名（测试脚本仍可读）：与 BYBOY_* 二选一即可
# BYBOY_TEST_OPENAI_MODEL=
# BYBOY_TEST_CLAUDE_MODEL=

# ---------- Firecrawl（byboy.agents.tutor_inf.web_clean）----------
# FIRECRAWL_API_KEY=
# 自建或代理时可改根 URL（不含路径，将请求 {BASE}/v2/scrape）
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# ---------- Firecrawl（网页抓取 / 搜索 / 爬站，供 Agent 调用 byboy.Firecrawl）----------
# FIRECRAWL_API_KEY=
# 可选：自建或代理时修改；默认 https://api.firecrawl.dev
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev
# 路径版本段，默认 v2（与官方当前 REST 一致）
# FIRECRAWL_API_VERSION=v2
